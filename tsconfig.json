{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "importHelpers": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "baseUrl": ".",
    "allowJs": true,
    "paths": {
      "@main/*":[
        "src/main/*"
      ],
      "@pre/*":[
        "src/preload/*"
      ],
      "@share/*":[
        "src/share/*"
      ],
    },
    "allowSyntheticDefaultImports": true
  }

}
